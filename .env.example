# Hackathon stack: HF Hub + Qwen (default) | optional vLLM on AMD Instinct + ROCm (e.g. AMD Developer Cloud).
# Default: Qwen via Hugging Face Serverless Inference (required on HF Spaces; see README).
# Local: vllm (OpenAI-compatible server on ROCm) | anthropic (local only; ignored on HF Spaces).
DAGINTEL_BACKEND=hf_inference

# Hugging Face — token must allow Inference API; create at https://huggingface.co/settings/tokens
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxx
# Model repo id (no huggingface/ prefix — code adds it for litellm)
# Must be a model your token can call on HF Inference (see model page → "Inference").
HF_MODEL=Qwen/Qwen2.5-7B-Instruct

# --- Local-only backends (disabled when running on a Hugging Face Space) ---

# vLLM / OpenAI-compatible (when DAGINTEL_BACKEND=vllm, local)
# VLLM_BASE_URL=http://localhost:8000/v1
# VLLM_MODEL=Qwen/Qwen3-32B
# VLLM_API_KEY=optional

# Anthropic (when DAGINTEL_BACKEND=anthropic, local — do not rely on this on public Spaces)
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Optional: cap size of log / DAG context embedded in the first agent task (see README)
# DAGINTEL_MAX_LOG_IN_PROMPT=120000
# DAGINTEL_MAX_CONTEXT_JSON_CHARS=8000

# Optional: crew / UI (see README)
# DAGINTEL_CREW_VERBOSE=false
# DAGINTEL_KICKOFF_TIMEOUT_SEC=600
# DAGINTEL_MAX_USER_LOG_CHARS=500000
# DAGINTEL_RATE_LIMIT_PER_HOUR=0

# Optional: cap on-screen agent output (full text in downloaded .md)
# DAGINTEL_MAX_DISPLAY_CHARS=80000

# Optional: LLM sampling (all backends using get_llm())
# DAGINTEL_LLM_TEMPERATURE=0.3
# DAGINTEL_LLM_MAX_TOKENS=2048

# Optional: offline regex tool for log analyzer (CrewAI) — raises iteration count slightly
# DAGINTEL_ENABLE_LOG_TOOLS=0
# DAGINTEL_LOG_ANALYZER_MAX_ITER=6
# DAGINTEL_LOG_TOOL_MAX_INPUT=200000
# DAGINTEL_LOG_TOOL_LIST_CAP=12

# Optional: OpenTelemetry
OTEL_EXPORTER_OTLP_ENDPOINT=
