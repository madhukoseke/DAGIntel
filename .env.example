# Hackathon stack: HF Hub + Qwen (default) | optional vLLM on AMD Instinct + ROCm (e.g. AMD Developer Cloud).
# Default: Qwen via Hugging Face Serverless Inference (required on HF Spaces; see README).
# Local: vllm (OpenAI-compatible server on ROCm) | anthropic (local only; ignored on HF Spaces).
DAGINTEL_BACKEND=hf_inference

# Hugging Face — token must allow Inference API; create at https://huggingface.co/settings/tokens
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxx
# Model repo id (no huggingface/ prefix — code adds it for litellm)
HF_MODEL=Qwen/QwQ-32B-Preview

# --- Local-only backends (disabled when running on a Hugging Face Space) ---

# vLLM / OpenAI-compatible (when DAGINTEL_BACKEND=vllm, local)
# VLLM_BASE_URL=http://localhost:8000/v1
# VLLM_MODEL=Qwen/Qwen3-32B
# VLLM_API_KEY=optional

# Anthropic (when DAGINTEL_BACKEND=anthropic, local — do not rely on this on public Spaces)
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Optional: OpenTelemetry
OTEL_EXPORTER_OTLP_ENDPOINT=
